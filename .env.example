# Helix configuration — copy to `.env` and fill in. ALL VALUES ARE OPTIONAL.
# With nothing set, Helix runs 100% locally and free (local embeddings + heuristic
# extractor + embedded SQLite store). Add a key only to improve extraction quality.

# ---------------------------------------------------------------------------
# LLM router (optional — used only for fact extraction / consolidation)
# Policy: heuristic pre-filter -> Gemini free tier -> gpt-4o-mini fallback.
# ---------------------------------------------------------------------------

# Preferred provider when a key is present: "gemini" | "openai" | "none"
HELIX_LLM_PROVIDER=none

# Google Gemini (free tier is the default cheap path)
GEMINI_API_KEY=
HELIX_GEMINI_MODEL=gemini-2.0-flash

# OpenAI (fallback; user has a paid gpt-4o-mini key)
OPENAI_API_KEY=
HELIX_OPENAI_MODEL=gpt-4o-mini

# ---------------------------------------------------------------------------
# Embeddings (default = local, $0). Switch to cloud only if you want to.
# ---------------------------------------------------------------------------
# "local" | "gemini" | "openai"
HELIX_EMBEDDINGS_PROVIDER=local
HELIX_LOCAL_EMBED_MODEL=BAAI/bge-small-en-v1.5

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
# Where strands live locally (default: ~/.helix)
HELIX_HOME=

# Passphrase used to derive the strand encryption key (Argon2id).
# Leave blank to use the device keychain instead.
HELIX_PASSPHRASE=

# ---------------------------------------------------------------------------
# Behavior / cost guardrails
# ---------------------------------------------------------------------------
# Hard monthly token ceiling for the LLM router; 0 = never call a paid model.
HELIX_MONTHLY_TOKEN_BUDGET=0
# Skip the LLM when the heuristic extractor is confident enough (0..1).
HELIX_HEURISTIC_CONFIDENCE_CUTOFF=0.75
# Telemetry is OFF by default and local-only when on.
HELIX_TELEMETRY=off
